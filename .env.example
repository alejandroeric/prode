# Plantilla de variables de entorno del Prode.
# Copiar este archivo como ".env" y completar con los valores reales.
# El archivo .env NUNCA se sube a git (ya esta en .gitignore).

# Puerto donde corre el servidor (opcional, por defecto 3001)
PORT=3001

# --- Supabase (se completan en el paso de configuracion de la base de datos) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Credenciales del administrador (Eric) ---
ADMIN_USUARIO=
ADMIN_PASSWORD=
